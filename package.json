{
  "name": "smart-project",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.33.4",
  "scripts": {
    "dev": "pnpm --filter @smart-project/web dev",
    "build": "pnpm --filter @smart-project/web generate",
    "test": "pnpm --filter @smart-project/engine test",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "pnpm": {
    "onlyBuiltDependencies": ["@parcel/watcher", "esbuild"]
  },
  "devDependencies": {
    "@eslint/js": "^9.39.0",
    "eslint": "^9.39.0",
    "eslint-config-prettier": "^10.1.0",
    "prettier": "^3.6.0",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.46.0"
  }
}
